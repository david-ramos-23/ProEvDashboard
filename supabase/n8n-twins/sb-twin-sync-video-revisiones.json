      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const mergeData = $('Merge').item.json;\nconst edicion = $input.item.json;                 // supabase row (flat snake_case)\nconst alumnoActual = $('Leer Alumno Actual').item.json; // supabase row (flat)\nlet rondas = [];\nconst plazosRaw = edicion.plazos_revision || '';\ntry { rondas = typeof plazosRaw === 'string' ? JSON.parse(plazosRaw) : (plazosRaw || []); } catch (e) { rondas = []; }\nconst now = new Date();\nlet plazoRevision = ''; let fechaPlazo = '';\nfor (const r of rondas) { if (now <= new Date(r.fecha + 'T23:59:59')) { plazoRevision = r.label; fechaPlazo = r.fecha; break; } }\n// FK shift: alumnos.edicion_id is a SCALAR UUID (not an array). Just set it to the active edition.\nconst edicionActivaId = edicion.id || '';\nreturn { json: { ...mergeData, edicionActivaId, edicionId: edicionActivaId, plazoRevision, fechaPlazo } };"
      },
