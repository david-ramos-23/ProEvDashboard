      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// SB-TWIN: input is Supabase DB Webhook payload, NEW row in body.record\nconst rec = ($input.item.json.body && $input.item.json.body.record) || $input.item.json.record || $input.item.json;\nconst revisionId   = rec.id;\nconst estadoRevision = rec.estado_revision || 'Pendiente';\nconst emailAlumno  = rec.email_alumno || '';\n// FK shift: linked array -> scalar UUID FK (no [0] indexing)\nconst alumnoId     = rec.alumno_id || '';\nconst revisor      = rec.revisor_responsable || 'Sin asignar';\nconst feedback     = rec.feedback || '';\nconst puntuacion   = rec.puntuacion || '';\nconst videoUrl     = rec.video_enviado || '';\nconst redesSociales = rec.redes_sociales || [];\nconst mapeo = { 'Pendiente':'En revisión de video','Aprobado':'Aprobado','Rechazado':'Rechazado','Revisión Necesaria':'En revisión de video' };\nconst nuevoEstadoGeneral = mapeo[estadoRevision] || 'En revisión de video';\nreturn { json: { revisionId, estadoRevision, emailAlumno, alumnoId, tieneAlumno: !!alumnoId, tieneEmail: !!emailAlumno, revisor, feedback, puntuacion, videoUrl, redesSociales, nuevoEstadoGeneral } };"
      },
