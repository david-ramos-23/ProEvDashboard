        "jsCode": "const emailAlumno = $('Extraer Datos').item.json.emailAlumno || '';\nconst alumnoId = $('Extraer Datos').item.json.alumnoId || $('Merge').item.json.alumnoId || '';\nconst trackPixel = 'https://hooks.dravaautomations.com/webhook/email-track?alumno=' + alumnoId + '&tipo=video-inaccesible';\nconst logo = 'https://sawa-dev-2-storage-bucket.storage.googleapis.com/profiles/nx0mtgi3zeb8acxp-d7a42.png';\n\nconst subject = 'Tu vídeo de candidatura no está accesible - ProEv';\n\nconst inner = '<div style=\"text-align:center;margin-bottom:30px\"><div style=\"font-size:36px\">&#128249;</div><h1 style=\"color:#0C5A45;font-size:24px;margin:10px 0\">&iexcl;Hola Candidato/a!</h1></div>'\n  + '<p style=\"color:#333;line-height:1.7;font-size:16px\">Hemos recibido tu candidatura, ¡gracias por participar en el proceso de selección de ProEv!</p>'\n  + '<p style=\"color:#333;line-height:1.7;font-size:16px\">Sin embargo, al intentar acceder al enlace de vídeo que nos has enviado, no hemos podido visualizarlo. El enlace no está accesible en este momento.</p>'\n  + '<div style=\"background:#f0f7f4;border-left:4px solid #0C5A45;border-radius:0 8px 8px 0;padding:20px;margin:25px 0\"><p style=\"color:#0C5A45;font-weight:600;margin:0 0 8px\">&#9888;&#65039; ¿Cómo solucionar esto?</p>'\n  + '<p style=\"color:#333;margin:0;line-height:1.7\">Por favor, revisa los permisos del enlace y asegúrate de que cualquier persona con el enlace pueda verlo:</p>'\n  + '<ul style=\"color:#333;margin:10px 0 0;padding-left:20px;line-height:1.9\"><li><strong>Google Drive:</strong> &quot;Cualquier persona con el enlace puede ver&quot;</li><li><strong>YouTube:</strong> vídeo público o no listado</li><li><strong>Otro servicio:</strong> accesible sin necesidad de iniciar sesión</li></ul></div>'\n  + '<p style=\"color:#333;line-height:1.7;font-size:16px\">Una vez corregido, responde a este email con el nuevo enlace y lo revisaremos lo antes posible.</p>'\n  + '<p style=\"color:#333;line-height:1.7;font-size:16px\">¡Muchas gracias por tu paciencia!</p>';\n\nconst sig = '<p style=\"margin:25px 0 0;text-align:center;font-size:15px;color:#1A1A1A;\"><strong>Alonso &amp; Noelia</strong></p>';\n\nconst social = '<p style=\"margin-bottom:15px;\"><a href=\"https://www.instagram.com/alonsoynoelia\" style=\"color:#1A1A1A;text-decoration:none;font-size:11px;font-weight:600;letter-spacing:1px;margin:0 8px;\">INSTAGRAM</a> <a href=\"https://www.youtube.com/@alonsoynoelia\" style=\"color:#1A1A1A;text-decoration:none;font-size:11px;font-weight:600;letter-spacing:1px;margin:0 8px;\">YOUTUBE</a> <a href=\"https://alonsoynoeliaonline.com\" style=\"color:#1A1A1A;text-decoration:none;font-size:11px;font-weight:600;letter-spacing:1px;margin:0 8px;\">WEB</a></p><p style=\"font-size:10px;color:#A9A9A9;margin:0;\">&copy; 2026 Alonso &amp; Noelia.</p>';\n\nconst htmlBody = '<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\"></head><body style=\"margin:0;padding:0\"><center><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#F6F3EE;\"><tr><td align=\"center\" valign=\"top\" style=\"padding:20px;\"><table width=\"500\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:500px;max-width:500px;margin:0 auto;font-family:Inter,Helvetica Neue,Arial,sans-serif;\"><tr><td align=\"center\" style=\"padding-bottom:25px;\"><img src=\"' + logo + '\" alt=\"Alonso y Noelia\" width=\"160\" style=\"display:block;\"></td></tr><tr><td style=\"background-color:#fff;border-radius:4px;overflow:hidden;box-shadow:0 5px 15px rgba(0,0,0,0.03);\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:40px 30px;font-size:16px;line-height:1.7;color:#333;\">' + inner + sig + '</td></tr></table></td></tr><tr><td style=\"padding:25px 0;text-align:center;\">' + social + '</td></tr></table></td></tr></table></center><img src=\"' + trackPixel + '\" width=\"1\" height=\"1\" style=\"display:none\" alt=\"\" /></body></html>';\n\nreturn { json: { email: emailAlumno, subject, htmlBody, idioma: '', alumnoId } };"
      }
    },
